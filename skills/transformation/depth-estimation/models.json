            }
          }
        },
        "win32": {
          "repository": "depth-anything/Depth-Anything-V2-Large",
          "format": "pth",
          "variants": {
            "depth_anything_v2_vitl": {
              "precision": "float32",
              "size_mb": 1280.0,
              "description": "PyTorch ViT-L — CUDA recommended"
            }
          }
        }
      }
    }
  }
